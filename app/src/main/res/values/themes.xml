<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NetProbe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/blue</item>
        <item name="colorPrimaryVariant">@color/lavender</item>
        <item name="colorOnPrimary">@color/crust</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/teal</item>
        <item name="colorSecondaryVariant">@color/green</item>
        <item name="colorOnSecondary">@color/crust</item>

        <!-- Error colors -->
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/crust</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/base</item>
        <item name="colorSurface">@color/surface0</item>
        <item name="colorOnSurface">@color/text</item>
        <item name="android:windowBackground">@color/base</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/crust</item>
        <item name="android:navigationBarColor">@color/crust</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/subtext0</item>
        <item name="android:textColorHint">@color/overlay0</item>

        <!-- Widget styles -->
        <item name="materialButtonStyle">@style/Widget.NetProbe.Button</item>
        <item name="materialCardViewStyle">@style/Widget.NetProbe.Card</item>
        <item name="textInputStyle">@style/Widget.NetProbe.TextInputLayout</item>
        <item name="bottomNavigationStyle">@style/Widget.NetProbe.BottomNav</item>
        <item name="toolbarStyle">@style/Widget.NetProbe.Toolbar</item>
        <item name="floatingActionButtonStyle">@style/Widget.NetProbe.FAB</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.NetProbe.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal</item>
        <item name="android:textColor">@color/crust</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.NetProbe.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/surface2</item>
        <item name="android:textColor">@color/text</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/surface1</item>
    </style>

    <style name="Widget.NetProbe.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/blue</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/surface1</item>
    </style>

    <style name="Widget.NetProbe.Button.Preset" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/surface2</item>
        <item name="android:textColor">@color/subtext0</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="rippleColor">@color/surface1</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.NetProbe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface0</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/surface1</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- TextInputLayout Style -->
    <style name="Widget.NetProbe.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/blue</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/blue</item>
        <item name="android:textColorHint">@color/overlay0</item>
        <item name="boxBackgroundColor">@color/mantle</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="Widget.NetProbe.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">@color/crust</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemRippleColor">@color/surface1</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.NetProbe.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/crust</item>
        <item name="titleTextColor">@color/text</item>
        <item name="subtitleTextColor">@color/subtext0</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.NetProbe.FAB" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/red</item>
        <item name="tint">@color/crust</item>
    </style>

    <!-- Progress Bar -->
    <style name="Widget.NetProbe.ProgressBar" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressTint">@color/teal</item>
        <item name="android:progressBackgroundTint">@color/surface1</item>
    </style>

</resources>
